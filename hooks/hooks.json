{
  "description": "Cortex memory — auto-recalls relevant memories on first message",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-recall.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
