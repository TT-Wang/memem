{
  "description": "memem — auto-recalls relevant memories on first message, topic-shift detection, and pre-tool-use file-read gating",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bootstrap.sh hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bootstrap.sh hook auto-recall",
            "timeout": 35
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bootstrap.sh hook pre-tool-use",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
